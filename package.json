{
  "name": "pi-mcp-adapter",
  "version": "2.2.1",
  "description": "MCP (Model Context Protocol) adapter extension for Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Nico Bailon",
  "bin": {
    "pi-mcp-adapter": "./cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nicobailon/pi-mcp-adapter"
  },
  "keywords": [
    "pi-package",
    "pi",
    "mcp",
    "model-context-protocol",
    "ai",
    "coding-agent",
    "extension",
    "claude",
    "llm"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "video": "https://github.com/nicobailon/pi-mcp-adapter/raw/refs/heads/main/pi-mcp.mp4"
  },
  "files": [
    "cli.js",
    "index.ts",
    "state.ts",
    "utils.ts",
    "tool-metadata.ts",
    "init.ts",
    "ui-session.ts",
    "proxy-modes.ts",
    "direct-tools.ts",
    "commands.ts",
    "types.ts",
    "ui-stream-types.ts",
    "config.ts",
    "server-manager.ts",
    "render.ts",
    "output-truncation.ts",
    "tool-registrar.ts",
    "resource-tools.ts",
    "lifecycle.ts",
    "metadata-cache.ts",
    "host-html-template.ts",
    "ui-resource-handler.ts",
    "consent-manager.ts",
    "ui-server.ts",
    "glimpse-ui.ts",
    "npx-resolver.ts",
    "oauth-handler.ts",
    "mcp-panel.ts",
    "logger.ts",
    "errors.ts",
    "app-bridge.bundle.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@sinclair/typebox": "^0.32.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
